#!/bin/bash
# WSL Boot Script for AerynOS
# Run: /etc/init.d/WSL-override start

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║                                                       ║"
echo "║           AerynOS WSL Distribution                    ║"
echo "║           基于 AerynOS 的 WSL 环境                        ║"
echo "║                                                       ║"
echo "║               aerynos-wsl.local -----------------     ║"
echo "║                                                       ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
echo ""
echo "WSL 2 - 优化模式，无需 GUI"
echo ""
echo "当前用户："
whoami
echo ""
echo "要运行命令，直接输入："
echo "  run <command>"
echo ""
echo "或者使用浏览器访问："
echo "  chromium <url>"
echo ""
echo "或重启 WSL："
echo "  reboot"
echo ""
echo "要安装新软件包，使用："
echo "  moss install <package>   安装软件"
echo "  moss sync -u            更新软件源"
echo ""
echo "其他有用命令："
echo "  moss search <query>     搜索软件包"
echo "  moss update             更新软件"
echo ""
echo "时区自动设置为：$(cat /etc/timezone 2>/dev/null || echo UTC)"
echo "locale 自动设置为：$(locale | grep LANG | cut -d= -f2 | tr -d ' ') 2>/dev/null || echo en_US.UTF-8"
echo ""
echo "请按 Enter 进入系统..."
read -r

exec /bin/bash
