# AerynOS WSL filesystem table
#
# Default WSL setup with host filesystem mount

# AerynOS root partition
LABEL=aerynos-root  / ext4 defaults 0 1

# WSL disk (mounted on Windows)
LABEL=wsl-disk /mnt/wsl auto defaults 0 0

# tmpfs for /run
tmpfs  /run tmpfs rw,nosuid,nodev,noexec,relatime,size=100M 0 0

# tmpfs for /dev/shm
tmpfs  /dev/shm tmpfs rw,nosuid,nodev 0 0

# proc filesystem
proc   /proc proc defaults 0 0

# sys filesystem
sys     /sys sysfs defaults 0 0

# WSL-specific: host directories
# Uncomment and configure as needed:
# LABEL=wsl-user-data /home/user-data auto defaults 0 0
