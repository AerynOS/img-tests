#!/bin/sh
# AerynOS WSL distribution entry point
# This script runs when WSL distribution starts

# Print welcome message
echo ""
echo "╔══════════════════════════════════════════"
echo "║           AerynOS WSL Distribution       ║"
echo "╚══════════════════════════════════════════"
echo ""

# Detect user
if [[ -f /etc/passwd ]]; then
    DEFAULT_USER=$(grep -oP '^(.*?)(?:\s+off)|(?:.*?)(?:\s+disabled)' /etc/passwd | cut -d: -f1 | head -1)
    if [[ -z "$DEFAULT_USER" ]]; then
        DEFAULT_USER="root"
    fi
else
    DEFAULT_USER="aerynos"
fi

# Check if we need to create user
if [[ ! -f /home/${DEFAULT_USER}/.profile ]]; then
    echo "[Setup Required] Run the following commands to create your user:"
    echo ""
    echo "  id: root"
    echo "  password: root123"
    echo ""
    echo "Then run:"
    echo "  adduser ${DEFAULT_USER}"
    echo "  passwd ${DEFAULT_USER}"
    echo "  usermod -aG sudo ${DEFAULT_USER}"
    echo ""
    echo "Press Enter to start as root directly..."
    read -r
else
    exec su - "$DEFAULT_USER" -c "$0"
fi
